<hc:Window x:Class="WF.MES.WPF.Auth.Views.ChangePasswordWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           xmlns:infra="clr-namespace:WF.MES.WPF.Ui"
           Title="{Binding TitleText}"
           Width="440"
           Height="420"
           MinWidth="400"
           MinHeight="380"
           ResizeMode="NoResize"
           WindowStartupLocation="CenterOwner"
           Background="White">
    <hc:Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Assets/Styles/LoginStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </hc:Window.Resources>

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="20"
                   FontWeight="SemiBold"
                   infra:Loc.Key="ui.password.firstLoginTitle" />
        <TextBlock Grid.Row="1"
                   Margin="0,8,0,24"
                   Foreground="{StaticResource AppTextMutedBrush}"
                   Text="{Binding HintText}"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="2"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource Boolean2BooleanReConverter}}">
            <TextBlock Style="{StaticResource LoginFieldLabelStyle}"
                       infra:Loc.Key="ui.password.new" />
            <PasswordBox x:Name="NewPasswordBox"
                         Margin="0,0,0,16"
                         PasswordChanged="NewPasswordBox_OnPasswordChanged"
                         Style="{StaticResource LoginPasswordBoxStyle}" />

            <TextBlock Style="{StaticResource LoginFieldLabelStyle}"
                       infra:Loc.Key="ui.password.confirm" />
            <PasswordBox x:Name="ConfirmPasswordBox"
                         PasswordChanged="ConfirmPasswordBox_OnPasswordChanged"
                         Style="{StaticResource LoginPasswordBoxStyle}" />

            <TextBlock Margin="0,8,0,0"
                       FontSize="12"
                       Foreground="{StaticResource AppTextMutedBrush}"
                       infra:Loc.Key="ui.password.ruleHint" />
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Margin="0,24,0,0"
                    HorizontalAlignment="Right"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource Boolean2BooleanReConverter}}"
                    Orientation="Horizontal">
            <Button Margin="0,0,12,0"
                    Command="{Binding CancelCommand}"
                    infra:Loc.Key="common.cancel"
                    Style="{StaticResource ButtonDefault}" />
            <Button Command="{Binding ConfirmCommand}"
                    infra:Loc.Key="ui.password.confirmChange"
                    Style="{StaticResource ButtonPrimary}" />
        </StackPanel>
    </Grid>
</hc:Window>
