<hc:Window x:Class="WF.MES.WPF.Auth.Views.LoginView"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:prism="http://prismlibrary.com/"
           xmlns:infra="clr-namespace:WF.MES.WPF.Ui"
           Title="WF MES"
           Icon="pack://application:,,,/Assets/app.ico"
           Width="920"
           Height="540"
           MinWidth="880"
           MinHeight="520"
           Background="{StaticResource AppBackgroundBrush}"
           ResizeMode="NoResize"
           ShowTitle="False"
           WindowStartupLocation="CenterScreen"
           prism:ViewModelLocator.AutoWireViewModel="True"
           mc:Ignorable="d">
    <hc:Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Assets/Styles/LoginStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </hc:Window.Resources>

    <Border Margin="16"
            Background="White"
            CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28"
                              Direction="270"
                              Opacity="0.18"
                              ShadowDepth="6"
                              Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧品牌区 -->
            <Border Grid.Column="0"
                    CornerRadius="16,0,0,16"
                    ClipToBounds="True">
                <Grid Background="{StaticResource AppBrandGradientDiagonal}">
                    <Ellipse Width="220"
                             Height="220"
                             Margin="-60,-80,0,0"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             Fill="#FFFFFF"
                             Opacity="0.06" />
                    <Ellipse Width="160"
                             Height="160"
                             Margin="0,0,-40,80"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Bottom"
                             Fill="#FFFFFF"
                             Opacity="0.08" />
                    <Ellipse Width="80"
                             Height="80"
                             Margin="40,0,0,120"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Bottom"
                             Fill="#FFFFFF"
                             Opacity="0.05" />

                    <StackPanel Margin="48"
                                VerticalAlignment="Center">
                        <Border Width="72"
                                Height="72"
                                Background="#FFFFFF"
                                CornerRadius="18"
                                Opacity="0.95">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12"
                                                  Opacity="0.2"
                                                  ShadowDepth="2" />
                            </Border.Effect>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AppPrimaryDarkBrush}"
                                       Text="WF" />
                        </Border>
                    </StackPanel>

                    <TextBlock Margin="24"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Bottom"
                               FontSize="12"
                               Foreground="{StaticResource AppOnBrandTextMutedBrush}"
                               Text="{Binding VersionText}" />
                </Grid>
            </Border>

            <!-- 右侧登录区 -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 语言 + 窗口关闭（仅登录页可选语言） -->
                <StackPanel Grid.Row="0"
                            Margin="0,12,12,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <TextBlock Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource AppTextMutedBrush}"
                               infra:Loc.Key="ui.locale.label" />
                    <ComboBox Width="120"
                              Height="32"
                              Margin="0,0,12,0"
                              VerticalAlignment="Center"
                              Background="White"
                              BorderBrush="{StaticResource AppBorderBrush}"
                              Foreground="{StaticResource AppTextPrimaryBrush}"
                              ItemsSource="{Binding LocaleOptions}"
                              SelectedItem="{Binding SelectedLocaleOption, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Foreground="{StaticResource AppTextPrimaryBrush}"
                                           Text="{Binding Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Width="36"
                            Height="36"
                            Click="CloseButton_Click"
                            Content="&#xE8BB;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="10"
                            Style="{StaticResource ButtonIcon}"
                            ToolTip="Close" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Margin="56,0,56,0"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AppTextPrimaryBrush}"
                               infra:Loc.Key="login.welcome" />
                    <TextBlock Margin="0,8,0,32"
                               FontSize="14"
                               Foreground="{StaticResource AppTextMutedBrush}"
                               infra:Loc.Key="ui.loginHint" />

                    <TextBlock Style="{StaticResource LoginFieldLabelStyle}"
                               infra:Loc.Key="login.usernameLabel" />
                    <hc:TextBox Height="44"
                                Margin="0,0,0,20"
                                hc:BorderElement.CornerRadius="8"
                                hc:InfoElement.Placeholder="{Binding UsernamePlaceholder}"
                                hc:InfoElement.ShowClearButton="True"
                                FontSize="14"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource Boolean2BooleanReConverter}}"
                                Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}">
                        <hc:TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding LoginCommand}" />
                        </hc:TextBox.InputBindings>
                    </hc:TextBox>

                    <TextBlock Style="{StaticResource LoginFieldLabelStyle}"
                               infra:Loc.Key="login.passwordLabel" />
                    <PasswordBox x:Name="PasswordBox"
                                 Margin="0,0,0,4"
                                 KeyDown="PasswordBox_OnKeyDown"
                                 PasswordChanged="PasswordBox_OnPasswordChanged"
                                 Style="{StaticResource LoginPasswordBoxStyle}" />

                    <Button Command="{Binding LoginCommand}"
                            infra:Loc.Key="login.submit"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource Boolean2BooleanReConverter}}"
                            Style="{StaticResource LoginPrimaryButtonStyle}" />
                </StackPanel>

                <!-- 底部状态 -->
                <Border Grid.Row="2"
                        Margin="32,0,32,24"
                        Padding="12,10"
                        Background="{StaticResource AppPanelBrush}"
                        CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ProgressBar Grid.Column="0"
                                     Width="80"
                                     Height="4"
                                     Margin="0,0,10,0"
                                     VerticalAlignment="Center"
                                     IsIndeterminate="True"
                                     Visibility="{Binding IsBusy, Converter={StaticResource Boolean2VisibilityConverter}}" />

                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{StaticResource AppTextMutedBrush}"
                                   Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <!-- 忙碌遮罩 -->
                <Border Grid.RowSpan="3"
                        Background="{StaticResource AppLoadingOverlayLightBrush}"
                        CornerRadius="0,16,16,0"
                        Visibility="{Binding IsBusy, Converter={StaticResource Boolean2VisibilityConverter}}" />
            </Grid>
        </Grid>
    </Border>
</hc:Window>
