<hc:Window x:Class="WF.MES.WPF.Views.Shell.ShellView"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:prism="http://prismlibrary.com/"
           xmlns:infra="clr-namespace:WF.MES.WPF.Infrastructure"
           Title="WF MES"
           Icon="pack://application:,,,/Assets/app.ico"
           Width="1280"
           Height="800"
           MinWidth="1024"
           MinHeight="640"
           WindowStartupLocation="CenterScreen"
           prism:ViewModelLocator.AutoWireViewModel="True"
           mc:Ignorable="d">
    <hc:Window.Resources>
        <Style x:Key="SubMenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AppNavHoverBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AppNavSelectedBrush}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModuleExpanderStyle" TargetType="Expander">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
        </Style>

        <Style x:Key="ShellHeaderSopButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="108" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource AppPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10"
                                                  Direction="270"
                                                  Opacity="0.22"
                                                  ShadowDepth="2"
                                                  Color="#000000" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AppHeaderButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AppHeaderButtonPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShellHeaderExitButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AppLoadingOverlayLightBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1AFFFFFF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </hc:Window.Resources>

    <DockPanel>
        <!-- 顶栏 -->
        <Border Height="64"
                Padding="20,0"
                Background="{StaticResource AppBrandGradientHorizontal}"
                DockPanel.Dock="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White"
                               infra:Loc.Key="ui.headerTitle" />
                    <StackPanel Margin="0,4,0,0"
                                Orientation="Horizontal">
                        <TextBlock FontSize="13"
                                   Foreground="{StaticResource AppHeaderSubtitleBrush}"
                                   Text="{Binding WelcomeText}" />
                        <TextBlock Margin="12,0,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource AppHeaderSubtitleBrush}"
                                   Text="·" />
                        <TextBlock Margin="12,0,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource AppHeaderSubtitleBrush}"
                                   Text="{Binding CurrentFactoryText}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Border Margin="0,0,16,0"
                            Padding="12,6"
                            VerticalAlignment="Center"
                            Background="#1FFFFFFF"
                            CornerRadius="14">
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{StaticResource AppHeaderBadgeTextBrush}"
                                   Text="{Binding VersionText}" />
                    </Border>
                    <TextBlock Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource AppHeaderSubtitleBrush}"
                               infra:Loc.Key="ui.locale.label" />
                    <ComboBox Width="120"
                              Height="32"
                              Margin="0,0,12,0"
                              VerticalAlignment="Center"
                              Foreground="{StaticResource AppHeaderSubtitleBrush}"
                              ItemsSource="{Binding LocaleOptions}"
                              SelectedItem="{Binding SelectedLocaleOption, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Foreground="{StaticResource AppTextPrimaryBrush}"
                                           Text="{Binding Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Command="{Binding SwitchFactoryCommand}"
                            Margin="0,0,10,0"
                            Style="{StaticResource ShellHeaderSopButtonStyle}"
                            Visibility="{Binding CanSwitchFactory, Converter={StaticResource Boolean2VisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,6,0"
                                       FontSize="15"
                                       Text="🏭" />
                            <TextBlock infra:Loc.Key="ui.factory.switch" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding OpenSopCommand}"
                            Style="{StaticResource ShellHeaderSopButtonStyle}"
                            ToolTip="{Binding [ui.openSop], Source={x:Static infra:Loc.LocSource}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,6,0"
                                       FontSize="15"
                                       Text="📖" />
                            <TextBlock infra:Loc.Key="ui.openSop" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding LogoutCommand}"
                            infra:Loc.Key="ui.logout"
                            Style="{StaticResource ShellHeaderExitButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 底部状态栏 -->
        <Border Height="28"
                Padding="16,0"
                Background="{StaticResource AppSidebarBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                DockPanel.Dock="Bottom">
            <Grid>
                <TextBlock VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Text="{Binding MachineNameText}" />
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <TextBlock FontSize="12"
                               Text="{Binding ApiStatusText}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource AppErrorBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsApiConnected}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AppSuccessBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Margin="8,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="|" />
                    <TextBlock FontSize="12"
                               Text="{Binding DatabaseStatusText}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource AppErrorBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDatabaseConnected}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AppSuccessBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                <TextBlock HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Text="{Binding CurrentTimeText}" />
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 功能模块 + 二级小菜单（树形） -->
            <Border Grid.Column="0"
                    Background="{StaticResource AppSidebarBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer Margin="0,8,0,0"
                              Padding="8,0,8,12"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Modules}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander Style="{StaticResource ModuleExpanderStyle}">
                                        <Expander.Header>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Margin="0,0,8,0"
                                                           FontSize="16"
                                                           Text="{Binding Icon}" />
                                                <TextBlock Grid.Column="1"
                                                           VerticalAlignment="Center"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding ModuleName}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource AppPrimaryBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Grid.Column="2"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Text="{Binding SubMenuCountText}" />
                                            </Grid>
                                        </Expander.Header>

                                        <!-- 二级小菜单 -->
                                        <ItemsControl Margin="8,4,0,8"
                                                      ItemsSource="{Binding SubMenus}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding DataContext.SelectMenuCommand, RelativeSource={RelativeSource AncestorType=hc:Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SubMenuButtonStyle}">
                                                        <StackPanel Margin="16,0,0,0"
                                                                    Orientation="Horizontal">
                                                            <TextBlock Margin="0,0,8,0"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       Text="└" />
                                                            <TextBlock VerticalAlignment="Center"
                                                                       FontSize="13"
                                                                       Text="{Binding MenuName}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{StaticResource AppTextBodyBrush}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                <Setter Property="Foreground" Value="{StaticResource AppPrimaryBrush}" />
                                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- 内容区 -->
            <Grid Grid.Column="1" Background="{StaticResource AppBackgroundBrush}">
                <ContentControl prism:RegionManager.RegionName="MainRegion" />

                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           IsHitTestVisible="False"
                           Text="{Binding EmptyHint}"
                           Visibility="{Binding ShowEmptyHint, Converter={StaticResource Boolean2VisibilityConverter}}" />
            </Grid>
        </Grid>
    </DockPanel>
</hc:Window>
