<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 间距 -->
    <Thickness x:Key="PageRootMargin">16</Thickness>
    <Thickness x:Key="PageToolbarMargin">0,12,0,8</Thickness>
    <Thickness x:Key="ContentSectionMargin">0,12,0,8</Thickness>
    <Thickness x:Key="FormDetailColumnMargin">16,0,0,0</Thickness>
    <Thickness x:Key="FormFieldLabelMargin">0,12,0,6</Thickness>
    <Thickness x:Key="FormFieldFirstLabelMargin">0,16,0,6</Thickness>
    <Thickness x:Key="FormSectionTitleMargin">0,16,0,6</Thickness>
    <Thickness x:Key="FormSaveButtonMargin">0,20,0,0</Thickness>
    <Thickness x:Key="PageToolbarButtonMargin">8,0,0,0</Thickness>
    <Thickness x:Key="PageSubtitleMargin">0,6,0,0</Thickness>
    <Thickness x:Key="InfoLineMargin">0,4,0,0</Thickness>

    <!-- 文本 -->
    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="FormTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="FormFieldLabelStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="{StaticResource FormFieldLabelMargin}" />
    </Style>

    <Style x:Key="FormFieldFirstLabelStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="{StaticResource FormFieldFirstLabelMargin}" />
    </Style>

    <Style x:Key="FormSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="{StaticResource FormSectionTitleMargin}" />
    </Style>

    <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="{StaticResource PageSubtitleMargin}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="PageHintTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="FormHintTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
    </Style>

    <Style x:Key="InfoPanelSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="InfoPanelLineStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="{StaticResource InfoLineMargin}" />
    </Style>

    <!-- 布局 -->
    <Style x:Key="PageToolbarPanelStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="Margin" Value="{StaticResource PageToolbarMargin}" />
    </Style>

    <Style x:Key="PageToolbarSecondaryButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource ButtonDefault}">
        <Setter Property="Margin" Value="{StaticResource PageToolbarButtonMargin}" />
    </Style>

    <Style x:Key="FormSaveButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource ButtonPrimary}">
        <Setter Property="Margin" Value="{StaticResource FormSaveButtonMargin}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="DetailPaneGridSplitterStyle" TargetType="GridSplitter">
        <Setter Property="Width" Value="6" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="ShowsPreview" Value="False" />
    </Style>

    <!-- 卡片 / 面板 -->
    <Style x:Key="FormCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="FormCardCompactBorderStyle"
           TargetType="Border"
           BasedOn="{StaticResource FormCardBorderStyle}">
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style x:Key="InfoPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AppPanelBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style x:Key="SegmentCardBorderStyle"
           TargetType="Border"
           BasedOn="{StaticResource FormCardCompactBorderStyle}">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="InfoPanelCompactBorderStyle"
           TargetType="Border"
           BasedOn="{StaticResource InfoPanelBorderStyle}">
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <!-- 加载遮罩 -->
    <Style x:Key="LoadingOverlayBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AppLoadingOverlayBrush}" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="LoadingOverlayPanelStyle" TargetType="StackPanel">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="LoadingOverlayMessageStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,12,0,0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource AppTextBodyBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

</ResourceDictionary>
