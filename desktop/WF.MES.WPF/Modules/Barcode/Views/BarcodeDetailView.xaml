<UserControl x:Class="WF.MES.WPF.Modules.Barcode.Views.BarcodeDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid Margin="{StaticResource PageRootMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource PageTitleStyle}"
                   Text="{Binding PageTitle}" />

        <TextBlock Grid.Row="1"
                   Style="{StaticResource PageSubtitleStyle}"
                   Text="{Binding RetentionHint}" />

        <StackPanel Grid.Row="2"
                    Style="{StaticResource PageToolbarPanelStyle}">
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding CustomerLabel}" />
            <ComboBox Width="140"
                      Margin="8,0,0,0"
                      DisplayMemberPath="CustomerName"
                      ItemsSource="{Binding Customers}"
                      SelectedItem="{Binding SelectedCustomer}" />
            <TextBlock Margin="16,0,0,0"
                       VerticalAlignment="Center"
                       Text="{Binding MaterialFilterLabel}" />
            <TextBox Width="140"
                     Margin="8,0,0,0"
                     Text="{Binding FilterMaterialNo, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Margin="16,0,0,0"
                       VerticalAlignment="Center"
                       Text="{Binding GenerateNoLabel}" />
            <TextBox Width="140"
                     Margin="8,0,0,0"
                     Text="{Binding FilterGenerateNo, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Margin="16,0,0,0"
                       VerticalAlignment="Center"
                       Text="{Binding GenerateTimeFromLabel}" />
            <DatePicker Width="130"
                        Margin="8,0,0,0"
                        SelectedDate="{Binding FilterCreatedFrom}" />
            <Button Margin="12,0,0,0"
                    Command="{Binding RefreshCommand}"
                    Content="{Binding Ui.Query}"
                    Style="{StaticResource ButtonPrimary}" />
            <Button Command="{Binding ExportCommand}"
                    Content="{Binding Ui.Export}"
                    Style="{StaticResource PageToolbarSecondaryButtonStyle}" />
        </StackPanel>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="360" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="420" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <DataGrid HorizontalAlignment="Stretch"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ItemsSource="{Binding GenerateRecords}"
                      SelectedItem="{Binding SelectedGenerateRecord}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{Binding DataContext.Ui.GenerateNo, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding GenerateNo}" Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="NoWrap" />
                                <Setter Property="TextTrimming" Value="None" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{Binding DataContext.Ui.Customer, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding CustomerName}" Width="90" />
                    <DataGridTextColumn Header="{Binding DataContext.Ui.MaterialNo, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding MaterialNo}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="NoWrap" />
                                <Setter Property="TextTrimming" Value="None" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{Binding DataContext.Ui.PrintDate, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding PrintDate, StringFormat=yyyy-MM-dd}" Width="100" />
                    <DataGridTextColumn Header="{Binding DataContext.Ui.Quantity, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding Quantity}" Width="60" />
                    <DataGridTextColumn Header="{Binding DataContext.Ui.SerialRange, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding SerialRangeText}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping" Value="NoWrap" />
                                <Setter Property="TextTrimming" Value="None" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{Binding DataContext.Ui.PrintStatus, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding PrintStatusText}" Width="80" />
                    <DataGridTextColumn Header="{Binding DataContext.Ui.CreatedAt, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="140" />
                    <DataGridTextColumn Header="{Binding DataContext.Ui.Operator, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding CreatedBy}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1"
                          Style="{StaticResource DetailPaneGridSplitterStyle}"
                          ResizeBehavior="PreviousAndNext" />

            <Grid Grid.Column="2">
                <Border Style="{StaticResource InfoPanelBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource InfoPanelSectionTitleStyle}"
                                   Text="{Binding DetailSectionTitle}" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding DetailGenerateNoLine}" />
                        <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                                   Text="{Binding DetailCustomerLine}" />
                        <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                                   Text="{Binding DetailMaterialNoLine}" />
                        <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                                   Text="{Binding DetailPrintDateLine}" />
                        <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                                   Text="{Binding DetailQuantityLine}" />
                        <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                                   Text="{Binding DetailSerialRangeLine}" />
                        <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                                   Text="{Binding DetailResetKeyLine}"
                                   TextTrimming="None"
                                   TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                                   Text="{Binding DetailPrintStatusLine}" />
                        <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                                   Text="{Binding SelectedGenerateRecord.LastReprintSummary}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding SelectedGenerateRecord.IsReprinted, Converter={StaticResource Boolean2VisibilityConverter}}" />
                        <TextBlock Margin="0,16,0,0"
                                   Style="{StaticResource PageHintTextStyle}"
                                   Text="{Binding ExportOnlyHint}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
