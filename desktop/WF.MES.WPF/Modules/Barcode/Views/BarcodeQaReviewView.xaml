<UserControl x:Class="WF.MES.WPF.Modules.Barcode.Views.BarcodeQaReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid Margin="{StaticResource PageRootMargin}"
          IsEnabled="{Binding IsBusy, Converter={StaticResource Boolean2BooleanReConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource PageTitleStyle}"
                   Text="{Binding PageTitle}" />

        <StackPanel Grid.Row="1"
                    Style="{StaticResource PageToolbarPanelStyle}">
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding Ui.Status}" />
            <ComboBox Margin="8,0,0,0"
                      Width="140"
                      DisplayMemberPath="DisplayText"
                      ItemsSource="{Binding StatusFilters}"
                      SelectedItem="{Binding SelectedStatusFilter}" />
            <TextBlock Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Text="{Binding Ui.Customer}" />
            <ComboBox Margin="8,0,0,0"
                      Width="120"
                      DisplayMemberPath="CustomerName"
                      ItemsSource="{Binding Customers}"
                      SelectedItem="{Binding SelectedCustomer}" />
            <TextBlock Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Text="{Binding Ui.MaterialNo}" />
            <TextBox Margin="8,0,0,0"
                     Width="120"
                     Text="{Binding FilterMaterialNo, UpdateSourceTrigger=LostFocus}" />
            <Button Margin="12,0,0,0"
                    Command="{Binding RefreshCommand}"
                    Content="{Binding Ui.Refresh}"
                    Style="{StaticResource ButtonDefault}" />
            <Button Command="{Binding OpenUploadCommand}"
                    Content="{Binding Ui.Upload}"
                    Style="{StaticResource PageToolbarSecondaryButtonStyle}"
                    Visibility="{Binding HasUploadPermission, Converter={StaticResource Boolean2VisibilityConverter}}" />
            <Button Command="{Binding OpenReviewCommand}"
                    Content="{Binding Ui.Review}"
                    Style="{StaticResource PageToolbarSecondaryButtonStyle}"
                    Visibility="{Binding HasReviewPermission, Converter={StaticResource Boolean2VisibilityConverter}}" />
        </StackPanel>

        <DataGrid Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="True"
                  IsReadOnly="True"
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{Binding DataContext.Ui.Customer, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding CustomerName}" Width="88" />
                <DataGridTextColumn Header="{Binding DataContext.Ui.MaterialNo, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding MaterialNo}" Width="110" />
                <DataGridTextColumn Header="{Binding DataContext.Ui.BarcodeLength, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding BarcodeLength}" Width="60" />
                <DataGridTextColumn Header="{Binding DataContext.Ui.Drawing, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding DrawingImageText}" Width="72" />
                <DataGridTextColumn Header="{Binding DataContext.Ui.SampleImage, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding PrintSampleImageText}" Width="76" />
                <DataGridTextColumn Header="{Binding DataContext.Ui.Status, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding QaStatusText}" Width="112" />
                <DataGridTextColumn Header="{Binding DataContext.Ui.CreatedBy, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding AttachmentUploadedByText}" Width="96" />
                <DataGridTextColumn Header="{Binding DataContext.Ui.CreatedAt, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding AttachmentUploadedAtText}" Width="156" />
                <DataGridTextColumn Header="{Binding DataContext.Ui.Reviewer, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding QaReviewedByText}" Width="96" />
                <DataGridTextColumn Header="{Binding DataContext.Ui.ReviewedAt, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding QaReviewedAtText}" Width="156" />
                <DataGridTextColumn Header="{Binding DataContext.Ui.RejectReason, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Binding="{Binding QaReviewRemarkText}"
                                    Width="*"
                                    MinWidth="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
