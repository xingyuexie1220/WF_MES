<UserControl x:Class="WF.MES.WPF.Modules.Barcode.Views.MaterialRuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:infra="clr-namespace:WF.MES.WPF.Ui"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:vm="clr-namespace:WF.MES.WPF.Modules.Barcode.ViewModels"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid Margin="{StaticResource PageRootMargin}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="320" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="440" MinWidth="400" />
        </Grid.ColumnDefinitions>
        <Grid IsEnabled="{Binding IsBusy, Converter={StaticResource Boolean2BooleanReConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Style="{StaticResource PageTitleStyle}"
                       Text="{Binding PageTitle}" />
            <StackPanel Grid.Row="1"
                        Style="{StaticResource PageToolbarPanelStyle}">
                <Button Command="{Binding AddCommand}"
                        infra:Loc.Key="ui.actions.add"
                        Style="{StaticResource ButtonPrimary}" />
                <Button Command="{Binding EditCommand}"
                        infra:Loc.Key="ui.actions.edit"
                        Style="{StaticResource PageToolbarSecondaryButtonStyle}" />
                <Button Command="{Binding RefreshCommand}"
                        infra:Loc.Key="ui.actions.refresh"
                        Style="{StaticResource PageToolbarSecondaryButtonStyle}" />
            </StackPanel>
            <DataGrid Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                      ItemsSource="{Binding Rules}" SelectedItem="{Binding SelectedRule}">
                <DataGrid.Columns>
                    <infra:LocDataGridTextColumn LocKey="ui.fields.customer" Binding="{Binding CustomerName}" Width="80" />
                    <infra:LocDataGridTextColumn LocKey="ui.fields.materialNo" Binding="{Binding MaterialNo}" Width="100" />
                    <infra:LocDataGridTextColumn LocKey="ui.fields.segment" Binding="{Binding SegmentSummary}" Width="*" MinWidth="120" />
                    <infra:LocDataGridTextColumn LocKey="ui.fields.barcodeLength" Binding="{Binding BarcodeLength}" Width="80" />
                    <infra:LocDataGridTextColumn LocKey="ui.fields.createdBy" Binding="{Binding CreatedByText}" Width="90" />
                    <infra:LocDataGridTextColumn LocKey="ui.fields.createdAt" Binding="{Binding CreateDateText}" Width="140" />
                    <infra:LocDataGridTextColumn LocKey="ui.fields.updatedBy" Binding="{Binding UpdatedByText}" Width="90" />
                    <infra:LocDataGridTextColumn LocKey="ui.fields.updatedAt" Binding="{Binding UpdatedAtText}" Width="140" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
        <GridSplitter Grid.Column="1"
                      Style="{StaticResource DetailPaneGridSplitterStyle}"
                      ResizeBehavior="PreviousAndNext" />
        <Grid Grid.Column="2"
              IsEnabled="{Binding IsBusy, Converter={StaticResource Boolean2BooleanReConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <TextBlock Style="{StaticResource FormTitleStyle}"
                           Text="{Binding FormTitle}" />
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="88" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Margin="0,0,0,6" infra:Loc.Key="ui.fields.customer" />
                        <ComboBox DisplayMemberPath="CustomerName" ItemsSource="{Binding Customers}"
                                  SelectedItem="{Binding SelectedCustomer}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Margin="0,0,0,6" infra:Loc.Key="ui.fields.materialNo" />
                        <TextBox Text="{Binding EditMaterialNo, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="12,0,0,0">
                        <TextBlock Margin="0,0,0,6" infra:Loc.Key="ui.fields.barcodeLength" />
                        <TextBox Text="{Binding EditBarcodeLength, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
                <StackPanel Margin="0,16,0,8" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding SegmentTitle}" />
                    <Button Margin="12,0,0,0" Command="{Binding AddSegmentCommand}" infra:Loc.Key="ui.actions.addSegment" Style="{StaticResource ButtonDefault}" />
                    <Button Margin="8,0,0,0" Command="{Binding PreviewCommand}" infra:Loc.Key="ui.actions.preview" Style="{StaticResource ButtonDefault}" />
                </StackPanel>
            </StackPanel>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Segments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:RuleSegmentItemViewModel}">
                            <Border Style="{StaticResource SegmentCardBorderStyle}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Text="{Binding SortOrderLabel}" />
                                        <ComboBox Grid.Column="1" Margin="8,0,0,0"
                                                  DisplayMemberPath="Display"
                                                  ItemsSource="{Binding DataContext.SegmentTypeOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedValue="{Binding SegmentType}"
                                                  SelectedValuePath="Value" />
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <Button Margin="8,0,0,0"
                                                    Command="{Binding DataContext.RemoveSegmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    infra:Loc.Key="ui.actions.delete"
                                                    Style="{StaticResource ButtonDefault}" />
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Margin="0,8,0,0">
                                        <StackPanel Visibility="{Binding IsLiteral, Converter={StaticResource Boolean2VisibilityConverter}}">
                                            <TextBlock infra:Loc.Key="ui.barcode.fixedContent" />
                                            <TextBox Text="{Binding LiteralValue, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Visibility="{Binding IsDate, Converter={StaticResource Boolean2VisibilityConverter}}">
                                            <TextBlock infra:Loc.Key="ui.barcode.dateFormat" />
                                            <ComboBox DisplayMemberPath="Display"
                                                      ItemsSource="{Binding DataContext.DateFormatOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedValue="{Binding DateFormat}"
                                                      SelectedValuePath="Value" />
                                        </StackPanel>
                                        <StackPanel Visibility="{Binding IsSerial, Converter={StaticResource Boolean2VisibilityConverter}}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Margin="0,0,8,0">
                                                    <TextBlock infra:Loc.Key="ui.barcode.serialRadix" />
                                                    <ComboBox DisplayMemberPath="Display"
                                                              ItemsSource="{Binding DataContext.SerialRadixOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              SelectedValue="{Binding SerialRadix}"
                                                              SelectedValuePath="Value" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                               Text="{Binding SerialRadixDescription}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock infra:Loc.Key="ui.barcode.serialDigits" />
                                                    <TextBox Text="{Binding SerialDigits, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                        <CheckBox Margin="0,8,0,0" infra:Loc.Key="ui.barcode.resetKey"
                                                  IsChecked="{Binding IncludeInResetKey}"
                                                  IsEnabled="{Binding IsSerial, Converter={StaticResource Boolean2BooleanReConverter}}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <StackPanel Grid.Row="2" Margin="0,12,0,0">
                <Border Style="{StaticResource InfoPanelCompactBorderStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource InfoPanelSectionTitleStyle}"
                                       infra:Loc.Key="ui.actions.preview" />
                            <DatePicker Grid.Column="1"
                                        Margin="12,0,0,0"
                                        HorizontalAlignment="Left"
                                        SelectedDate="{Binding PreviewDate}" />
                        </Grid>
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding PreviewText}"
                                   TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="{Binding TotalLengthText}"
                                   Visibility="{Binding ShowPreviewLength, Converter={StaticResource Boolean2VisibilityConverter}}" />
                    </StackPanel>
                </Border>
                <Button Command="{Binding SaveCommand}"
                        infra:Loc.Key="ui.actions.saveRule"
                        Style="{StaticResource FormSaveButtonStyle}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
