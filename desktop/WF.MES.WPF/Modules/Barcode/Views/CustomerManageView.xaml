<UserControl x:Class="WF.MES.WPF.Modules.Barcode.Views.CustomerManageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid Margin="{StaticResource PageRootMargin}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <Grid IsEnabled="{Binding IsBusy, Converter={StaticResource Boolean2BooleanReConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Style="{StaticResource PageTitleStyle}"
                       Text="{Binding PageTitle}" />

            <StackPanel Grid.Row="1"
                        Style="{StaticResource PageToolbarPanelStyle}">
                <Button Command="{Binding AddCommand}"
                        Content="{Binding Ui.Add}"
                        Style="{StaticResource ButtonPrimary}" />
                <Button Command="{Binding EditCommand}"
                        Content="{Binding Ui.Edit}"
                        Style="{StaticResource PageToolbarSecondaryButtonStyle}" />
                <Button Command="{Binding RefreshCommand}"
                        Content="{Binding Ui.Refresh}"
                        Style="{StaticResource PageToolbarSecondaryButtonStyle}" />
            </StackPanel>

            <DataGrid Grid.Row="2"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      ItemsSource="{Binding Customers}"
                      SelectedItem="{Binding SelectedCustomer}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{Binding DataContext.Ui.CustomerName, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Binding="{Binding CustomerName}"
                                        Width="*"
                                        MinWidth="100" />
                    <DataGridTextColumn Header="{Binding DataContext.Ui.Status, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Binding="{Binding EnableText}"
                                        Width="60" />
                    <DataGridTextColumn Header="{Binding DataContext.Ui.CreatedBy, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Binding="{Binding CreatedByText}"
                                        Width="90" />
                    <DataGridTextColumn Header="{Binding DataContext.Ui.CreatedAt, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Binding="{Binding CreateDateText}"
                                        Width="140" />
                    <DataGridTextColumn Header="{Binding DataContext.Ui.UpdatedBy, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Binding="{Binding UpdatedByText}"
                                        Width="90" />
                    <DataGridTextColumn Header="{Binding DataContext.Ui.UpdatedAt, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Binding="{Binding UpdatedAtText}"
                                        Width="140" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Column="1"
                Margin="{StaticResource FormDetailColumnMargin}"
                Style="{StaticResource FormCardBorderStyle}"
                IsEnabled="{Binding IsBusy, Converter={StaticResource Boolean2BooleanReConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Style="{StaticResource FormTitleStyle}"
                               Text="{Binding FormTitle}" />
                    <TextBlock Style="{StaticResource FormFieldFirstLabelStyle}"
                               Text="{Binding CustomerNameLabel}" />
                    <TextBox Text="{Binding EditCustomerName, UpdateSourceTrigger=PropertyChanged}" />
                    <CheckBox Margin="0,12,0,0"
                              Content="{Binding Ui.Enable}"
                              IsChecked="{Binding CustomerEnabled}" />
                    <Button Command="{Binding SaveCommand}"
                            Content="{Binding SaveCustomerText}"
                            Style="{StaticResource FormSaveButtonStyle}" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
