<UserControl x:Class="WF.MES.WPF.Modules.Barcode.Views.BarcodeReprintView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid Margin="{StaticResource PageRootMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource PageTitleStyle}"
                   Text="{Binding PageTitle}" />

        <TextBlock Grid.Row="1"
                   Style="{StaticResource PageSubtitleStyle}"
                   Text="{Binding PageHint}" />

        <StackPanel Grid.Row="2"
                    Style="{StaticResource PageToolbarPanelStyle}">
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding CustomerLabel}" />
            <ComboBox Width="120"
                      Margin="8,0,0,0"
                      DisplayMemberPath="CustomerName"
                      ItemsSource="{Binding Customers}"
                      SelectedItem="{Binding SelectedCustomer}" />
            <TextBlock Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Text="{Binding MaterialNoLabel}" />
            <TextBox Width="120"
                     Margin="8,0,0,0"
                     Text="{Binding FilterMaterialNo, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Text="{Binding GenerateNoLabel}" />
            <TextBox Width="140"
                     Margin="8,0,0,0"
                     Text="{Binding FilterGenerateNo, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Text="{Binding GenerateTimeFromLabel}" />
            <DatePicker Width="130"
                        Margin="8,0,0,0"
                        SelectedDate="{Binding FilterCreatedFrom}" />
            <Button Margin="12,0,0,0"
                    Command="{Binding RefreshCommand}"
                    Content="{Binding Ui.Query}"
                    Style="{StaticResource ButtonPrimary}" />
        </StackPanel>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="420" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="320" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <DataGrid AutoGenerateColumns="False"
                      IsReadOnly="True"
                      ItemsSource="{Binding GenerateRecords}"
                      SelectedItem="{Binding SelectedGenerateRecord}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{Binding DataContext.Ui.GenerateNo, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding GenerateNo}" Width="150" />
                    <DataGridTextColumn Header="{Binding DataContext.Ui.Customer, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding CustomerName}" Width="90" />
                    <DataGridTextColumn Header="{Binding DataContext.Ui.MaterialNo, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding MaterialNo}" Width="120" />
                    <DataGridTextColumn Header="{Binding DataContext.Ui.Quantity, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding Quantity}" Width="70" />
                    <DataGridTextColumn Header="{Binding DataContext.Ui.SerialRange, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding SerialRangeText}" Width="120" />
                    <DataGridTextColumn Header="{Binding DataContext.Ui.PrintStatus, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding PrintStatusText}" Width="80" />
                    <DataGridTextColumn Header="{Binding DataContext.Ui.ReprintAt, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding LastReprintedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="130" />
                    <DataGridTextColumn Header="{Binding DataContext.Ui.ReprintBy, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding LastReprintedBy}" Width="90" />
                    <DataGridTextColumn Header="{Binding DataContext.Ui.CreatedAt, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="140" />
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1"
                          Style="{StaticResource DetailPaneGridSplitterStyle}"
                          ResizeBehavior="PreviousAndNext" />

            <Border Grid.Column="2"
                    Style="{StaticResource InfoPanelBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource InfoPanelSectionTitleStyle}"
                               Text="{Binding ReprintInfoTitle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding ReprintDetailGenerateNoLine}" />
                    <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                               Text="{Binding ReprintDetailCustomerLine}" />
                    <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                               Text="{Binding ReprintDetailMaterialNoLine}" />
                    <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                               Text="{Binding ReprintDetailQuantityLine}" />
                    <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                               Text="{Binding ReprintDetailSerialRangeLine}" />
                    <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                               Text="{Binding ReprintDetailPrintStatusLine}" />
                    <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                               Text="{Binding ReprintDetailReprintAtLine}"
                               Visibility="{Binding SelectedGenerateRecord.IsReprinted, Converter={StaticResource Boolean2VisibilityConverter}}" />
                    <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                               Text="{Binding ReprintDetailReprintByLine}"
                               Visibility="{Binding SelectedGenerateRecord.IsReprinted, Converter={StaticResource Boolean2VisibilityConverter}}" />
                    <StackPanel Margin="0,16,0,0"
                                Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding PrinterLabel}" />
                        <ComboBox Width="220"
                                  Margin="8,0,0,0"
                                  IsEnabled="{Binding ShowPrintingOverlay, Converter={StaticResource Boolean2BooleanReConverter}}"
                                  ItemsSource="{Binding Printers}"
                                  SelectedItem="{Binding SelectedPrinter}" />
                    </StackPanel>
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource PageHintTextStyle}"
                               Text="{Binding PrintStatus}" />
                    <Button Margin="0,12,0,0"
                            HorizontalAlignment="Left"
                            Command="{Binding ReprintCommand}"
                            Content="{Binding ExecuteReprintText}"
                            Style="{StaticResource ButtonPrimary}" />
                </StackPanel>
            </Border>

            <Border Grid.ColumnSpan="3"
                    Background="{StaticResource AppLoadingOverlayBrush}"
                    Visibility="{Binding ShowPrintingOverlay, Converter={StaticResource Boolean2VisibilityConverter}}">
                <StackPanel Style="{StaticResource LoadingOverlayPanelStyle}">
                    <ProgressBar Width="200"
                                 Height="4"
                                 IsIndeterminate="True" />
                    <TextBlock Style="{StaticResource LoadingOverlayMessageStyle}"
                               Text="{Binding PrintStatus}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
