<hc:Window x:Class="WF.MES.WPF.Modules.Barcode.Views.BarcodeQaReviewDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:infra="clr-namespace:WF.MES.WPF.Ui"
        Title="{Binding WindowTitle}"
        Width="920"
        Height="720"
        MinWidth="760"
        MinHeight="600"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <Grid Margin="{StaticResource PageRootMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource PageTitleStyle}"
                   Text="{Binding TitleText}" />

        <Border Grid.Row="1"
                Margin="{StaticResource ContentSectionMargin}"
                Style="{StaticResource InfoPanelBorderStyle}">
            <StackPanel DataContext="{Binding Detail}">
                <infra:LocInfoField LabelKey="ui.fields.barcodeLength"
                                    ValuePath="BarcodeLength" />
                <infra:LocInfoField Margin="{StaticResource InfoLineMargin}"
                                    EnumMap="qaStatus"
                                    LabelKey="ui.fields.status"
                                    ValuePath="QaStatus" />
                <infra:LocInfoField Margin="{StaticResource InfoLineMargin}"
                                    LabelKey="ui.fields.createdBy"
                                    ValuePath="AttachmentUploadedByText" />
                <infra:LocInfoField Margin="{StaticResource InfoLineMargin}"
                                    LabelKey="ui.fields.createdAt"
                                    ValuePath="AttachmentUploadedAtText" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" infra:Loc.Key="ui.barcode.qaDrawingPreview" />
                <Border Grid.Row="1"
                        Margin="0,6,0,0"
                        Background="#F7F7F7"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <Image Source="{Binding DrawingPreview}" Stretch="Uniform" />
                </Border>
            </Grid>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" infra:Loc.Key="ui.barcode.qaSamplePreview" />
                <Border Grid.Row="1"
                        Margin="0,6,0,0"
                        Background="#F7F7F7"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <Image Source="{Binding PrintSamplePreview}" Stretch="Uniform" />
                </Border>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="3" Margin="0,16,0,0">
            <TextBlock infra:Loc.Key="ui.barcode.qaRejectReasonRequired" />
            <TextBox Margin="0,6,0,0"
                     AcceptsReturn="True"
                     Height="72"
                     MaxLength="500"
                     IsEnabled="{Binding IsBusy, Converter={StaticResource Boolean2BooleanReConverter}}"
                     Text="{Binding RejectRemark, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center"
                       Foreground="#666"
                       infra:Loc.Key="ui.barcode.qaApproveHint"
                       TextWrapping="Wrap" />
            <Button Grid.Column="1"
                    Margin="0,0,8,0"
                    Command="{Binding ApproveCommand}"
                    infra:Loc.Key="ui.actions.approve"
                    Style="{StaticResource ButtonPrimary}" />
            <Button Grid.Column="2"
                    Margin="0,0,8,0"
                    Command="{Binding RejectCommand}"
                    infra:Loc.Key="ui.actions.reject"
                    Style="{StaticResource ButtonDefault}" />
            <Button Grid.Column="3"
                    Command="{Binding CloseCommand}"
                    infra:Loc.Key="common.cancel"
                    Style="{StaticResource ButtonDefault}" />
        </Grid>

        <Border Grid.RowSpan="5"
                Style="{StaticResource LoadingOverlayBorderStyle}"
                Visibility="{Binding IsBusy, Converter={StaticResource Boolean2VisibilityConverter}}">
            <StackPanel Style="{StaticResource LoadingOverlayPanelStyle}">
                <ProgressBar Width="200"
                             Height="4"
                             IsIndeterminate="True" />
                <TextBlock Style="{StaticResource LoadingOverlayMessageStyle}"
                           infra:Loc.Key="ui.actions.processing" />
            </StackPanel>
        </Border>
    </Grid>
</hc:Window>
