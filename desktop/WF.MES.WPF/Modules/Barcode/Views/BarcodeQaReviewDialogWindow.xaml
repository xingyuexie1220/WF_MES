<hc:Window x:Class="WF.MES.WPF.Modules.Barcode.Views.BarcodeQaReviewDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="{Binding WindowTitle}"
        Width="920"
        Height="720"
        MinWidth="760"
        MinHeight="600"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <Grid Margin="{StaticResource PageRootMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource PageTitleStyle}"
                   Text="{Binding TitleText}" />

        <Border Grid.Row="1"
                Margin="{StaticResource ContentSectionMargin}"
                Style="{StaticResource InfoPanelBorderStyle}">
            <StackPanel>
                <TextBlock Text="{Binding BarcodeTotalLengthLine}" />
                <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                           Text="{Binding QaStatusLine}" />
                <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                           Text="{Binding UploadedByLine}" />
                <TextBlock Style="{StaticResource InfoPanelLineStyle}"
                           Text="{Binding UploadedAtLine}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding DrawingPreviewTitle}" />
                <Border Grid.Row="1"
                        Margin="0,6,0,0"
                        Background="#F7F7F7"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <Image Source="{Binding DrawingPreview}" Stretch="Uniform" />
                </Border>
            </Grid>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding SamplePreviewTitle}" />
                <Border Grid.Row="1"
                        Margin="0,6,0,0"
                        Background="#F7F7F7"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <Image Source="{Binding PrintSamplePreview}" Stretch="Uniform" />
                </Border>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="3" Margin="0,16,0,0">
            <TextBlock Text="{Binding RejectReasonLabel}" />
            <TextBox Margin="0,6,0,0"
                     AcceptsReturn="True"
                     Height="72"
                     MaxLength="500"
                     IsEnabled="{Binding IsBusy, Converter={StaticResource Boolean2BooleanReConverter}}"
                     Text="{Binding RejectRemark, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center"
                       Foreground="#666"
                       Text="{Binding ApproveHint}"
                       TextWrapping="Wrap" />
            <Button Grid.Column="1"
                    Margin="0,0,8,0"
                    Command="{Binding ApproveCommand}"
                    Content="{Binding ApproveText}"
                    Style="{StaticResource ButtonPrimary}" />
            <Button Grid.Column="2"
                    Margin="0,0,8,0"
                    Command="{Binding RejectCommand}"
                    Content="{Binding RejectText}"
                    Style="{StaticResource ButtonDefault}" />
            <Button Grid.Column="3"
                    Command="{Binding CloseCommand}"
                    Content="{Binding Ui.Cancel}"
                    Style="{StaticResource ButtonDefault}" />
        </Grid>

        <Border Grid.RowSpan="5"
                Style="{StaticResource LoadingOverlayBorderStyle}"
                Visibility="{Binding IsBusy, Converter={StaticResource Boolean2VisibilityConverter}}">
            <StackPanel Style="{StaticResource LoadingOverlayPanelStyle}">
                <ProgressBar Width="200"
                             Height="4"
                             IsIndeterminate="True" />
                <TextBlock Style="{StaticResource LoadingOverlayMessageStyle}"
                           Text="{Binding Ui.Processing}" />
            </StackPanel>
        </Border>
    </Grid>
</hc:Window>
